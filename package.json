{
  "name": "@retr0/sts-cli",
  "version": "0.1.0",
  "description": "Global CLI for interacting with the local STS2 Taku Agent observer server.",
  "type": "module",
  "bin": {
    "sts": "./bin/sts.js"
  },
  "files": [
    "bin/",
    "dist/npm/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "sts": "node --experimental-strip-types cli/main.ts",
    "build:cli": "tsc -p tsconfig.build.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "test:cli": "STS_CLI_TEST=1 node --experimental-strip-types --test cli/**/*.test.ts",
    "verify:cli": "npm run check && npm run test:cli",
    "pack:cli": "npm run build:cli && npm pack --dry-run",
    "build:release": "scripts/build-release.sh",
    "prepack": "npm run build:cli"
  },
  "keywords": [
    "slay-the-spire-2",
    "sts2",
    "cli",
    "agent"
  ],
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.9.3"
  }
}
