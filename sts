#!/usr/bin/env bash
set -euo pipefail

BASE_URL="${STS_OBSERVER_URL:-http://127.0.0.1:15527}"
CURL_BIN="${CURL_BIN:-$(command -v curl)}"
JQ_BIN="${JQ_BIN:-$(command -v jq || true)}"

print_usage() {
  cat <<'EOF'
Usage:
  ./sts help
  ./sts ping
  ./sts capabilities
  ./sts context
  ./sts next
  ./sts compact
  ./sts delta
  ./sts actions
  ./sts run
  ./sts knowledge [current|cards|relics|potions|status]
  ./sts player [summary|deck|relics|potions|status]
  ./sts combat [summary|actions|hand|enemies|piles]
  ./sts map
  ./sts event
  ./sts shop
  ./sts rest-site
  ./sts rewards
  ./sts card-reward
  ./sts card-selection
  ./sts treasure
  ./sts exec ACTION [INDEX] [TARGET]
  ./sts exec ACTION [key=value ...]
  ./sts full
  ./sts get /api/v1/...

Environment:
  STS_OBSERVER_URL   Override observer server base URL.

Examples:
  ./sts ping
  ./sts next
  ./sts actions
  ./sts combat actions
  ./sts player summary
  ./sts knowledge cards
  ./sts exec play_card 0 jaw_worm_0
  ./sts exec select_card 1
  ./sts exec end_turn
  ./sts get /api/v1/state/full
EOF
}

pretty_print() {
  if [[ -n "${JQ_BIN:-}" ]]; then
    "${JQ_BIN}" .
  else
    cat
  fi
}

request() {
  local path="$1"
  "${CURL_BIN}" -fsS "${BASE_URL}${path}"
}

request_post() {
  local path="$1"
  local body="$2"
  "${CURL_BIN}" -fsS -X POST -H 'Content-Type: application/json' -d "${body}" "${BASE_URL}${path}"
}

request_and_print() {
  local path="$1"
  request "${path}" | pretty_print
}

command_ping() {
  request_and_print "/"
}

command_capabilities() {
  request_and_print "/api/v1/capabilities"
}

command_context() {
  request_and_print "/api/v1/context"
}

command_next() {
  local context_json
  local compact_json

  context_json="$(request "/api/v1/context")"
  compact_json="$(request "/api/v1/observation/compact")"

  if [[ -n "${JQ_BIN:-}" ]]; then
    "${JQ_BIN}" -n \
      --argjson context "${context_json}" \
      --argjson observation "${compact_json}" \
      '{context: $context, observation: $observation}'
  else
    printf '%s\n' "Context:"
    printf '%s\n' "${context_json}"
    printf '\n%s\n' "Observation:"
    printf '%s\n' "${compact_json}"
  fi
}

command_compact() {
  request_and_print "/api/v1/observation/compact"
}

command_delta() {
  request_and_print "/api/v1/observation/delta"
}

command_actions() {
  request_and_print "/api/v1/actions"
}

command_run() {
  request_and_print "/api/v1/run"
}

command_knowledge() {
  local section="${1:-current}"
  case "${section}" in
    current) request_and_print "/api/v1/knowledge/current" ;;
    cards) request_and_print "/api/v1/knowledge/cards" ;;
    relics) request_and_print "/api/v1/knowledge/relics" ;;
    potions) request_and_print "/api/v1/knowledge/potions" ;;
    status) request_and_print "/api/v1/knowledge/status" ;;
    *)
      printf 'Unknown knowledge subcommand: %s\n' "${section}" >&2
      exit 1
      ;;
  esac
}

command_player() {
  local section="${1:-summary}"
  case "${section}" in
    summary) request_and_print "/api/v1/player/summary" ;;
    deck) request_and_print "/api/v1/player/deck" ;;
    relics) request_and_print "/api/v1/player/relics" ;;
    potions) request_and_print "/api/v1/player/potions" ;;
    status) request_and_print "/api/v1/player/status" ;;
    *)
      printf 'Unknown player subcommand: %s\n' "${section}" >&2
      exit 1
      ;;
  esac
}

command_combat() {
  local section="${1:-summary}"
  case "${section}" in
    summary) request_and_print "/api/v1/combat/summary" ;;
    actions) request_and_print "/api/v1/combat/actions" ;;
    hand) request_and_print "/api/v1/combat/hand" ;;
    enemies) request_and_print "/api/v1/combat/enemies" ;;
    piles) request_and_print "/api/v1/combat/piles" ;;
    *)
      printf 'Unknown combat subcommand: %s\n' "${section}" >&2
      exit 1
      ;;
  esac
}

command_get() {
  local path="${1:-}"
  if [[ -z "${path}" ]]; then
    printf 'Usage: ./sts get /api/v1/...\n' >&2
    exit 1
  fi

  request_and_print "${path}"
}

json_escape() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  value="${value//$'\n'/\\n}"
  printf '%s' "${value}"
}

json_value() {
  local value="$1"
  if [[ "${value}" =~ ^-?[0-9]+$ ]]; then
    printf '%s' "${value}"
  elif [[ "${value}" == "true" || "${value}" == "false" || "${value}" == "null" ]]; then
    printf '%s' "${value}"
  else
    printf '"%s"' "$(json_escape "${value}")"
  fi
}

build_exec_body() {
  local action="$1"
  shift || true

  local body
  body='{"actionType":"'"$(json_escape "${action}")"'","parameters":{'
  local first=1
  local pair key value

  if [[ $# -gt 0 && "$1" != *=* ]]; then
    if [[ $# -gt 2 ]]; then
      printf 'Positional exec form supports at most ACTION [INDEX] [TARGET]\n' >&2
      exit 1
    fi

    body+='"index":'"$(json_value "$1")"
    if [[ $# -eq 2 ]]; then
      body+=',"target":'"$(json_value "$2")"
    fi
    body+='}}'
    printf '%s' "${body}"
    return
  fi

  for pair in "$@"; do
    if [[ "${pair}" != *=* ]]; then
      printf 'Execution arguments must use key=value format: %s\n' "${pair}" >&2
      exit 1
    fi

    key="${pair%%=*}"
    value="${pair#*=}"

    if [[ ${first} -eq 0 ]]; then
      body+=','
    fi

    body+='"'"$(json_escape "${key}")"'":'"$(json_value "${value}")"
    first=0
  done

  body+='}}'
  printf '%s' "${body}"
}

command_exec() {
  local action="${1:-}"
  shift || true

  if [[ -z "${action}" ]]; then
    printf 'Usage: ./sts exec ACTION [key=value ...]\n' >&2
    exit 1
  fi

  request_post "/api/v1/actions/execute" "$(build_exec_body "${action}" "$@")" | pretty_print
}

main() {
  local command="${1:-help}"
  shift || true

  case "${command}" in
    help|-h|--help) print_usage ;;
    ping) command_ping ;;
    capabilities) command_capabilities ;;
    context) command_context ;;
    next) command_next ;;
    compact|observe|observation) command_compact ;;
    delta) command_delta ;;
    actions) command_actions ;;
    run) command_run ;;
    knowledge) command_knowledge "$@" ;;
    player) command_player "$@" ;;
    combat) command_combat "$@" ;;
    map) request_and_print "/api/v1/map/summary" ;;
    event) request_and_print "/api/v1/event" ;;
    shop) request_and_print "/api/v1/shop" ;;
    rest-site|rest) request_and_print "/api/v1/rest-site" ;;
    rewards) request_and_print "/api/v1/rewards" ;;
    card-reward) request_and_print "/api/v1/card-reward" ;;
    card-selection|card-select) request_and_print "/api/v1/card-selection" ;;
    treasure) request_and_print "/api/v1/treasure" ;;
    exec|do|act) command_exec "$@" ;;
    full) request_and_print "/api/v1/state/full" ;;
    get) command_get "$@" ;;
    *)
      printf 'Unknown command: %s\n\n' "${command}" >&2
      print_usage >&2
      exit 1
      ;;
  esac
}

main "$@"
