#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
  SOURCE_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
  SOURCE_TARGET="$(readlink "$SOURCE")"
  if [[ "$SOURCE_TARGET" != /* ]]; then
    SOURCE="${SOURCE_DIR}/${SOURCE_TARGET}"
  else
    SOURCE="$SOURCE_TARGET"
  fi
done

ROOT_DIR="$(cd "$(dirname "$SOURCE")/.." && pwd)"
if [[ -f "${ROOT_DIR}/dist/npm/main.js" ]]; then
  exec node "${ROOT_DIR}/dist/npm/main.js" "$@"
fi

exec node --experimental-strip-types "${ROOT_DIR}/tools/sts-cli/main.ts" "$@"
